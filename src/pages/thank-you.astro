---
import Base from '../layouts/Base.astro';

---
<Base
  title="Thank You — EverCheck"
  description="Thank you for reaching out to EverCheck. We will get back to you within one business day."
>
<style>
body {
    font-family:'DM Sans',system-ui,-apple-system,sans-serif;
    color:var(--brand-black);
    font-size:16px;
    line-height:1.75;
    -webkit-font-smoothing:antialiased;
}
/* Thank You */
.thank-you-section {
    min-height:80vh;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:120px 24px 80px;
}
.thank-you-card { max-width:560px; margin:0 auto; }
.thank-you-icon {
    width:80px; height:80px;
    border-radius:50%;
    background:rgba(128,188,226,0.12);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 32px;
}
.thank-you-icon svg {
    width:40px; height:40px;
    stroke:var(--brand-blue); fill:none;
    stroke-width:2; stroke-linecap:round; stroke-linejoin:round;
}
.thank-you-card h1 {
    font-size:36px; font-weight:700;
    color:var(--brand-black);
    margin-bottom:16px; line-height:1.3;
}
.thank-you-card p {
    font-size:17px; color:var(--brand-gray);
    margin-bottom:8px; line-height:1.65;
}
.thank-you-card .highlight { color:var(--brand-blue); font-weight:600; }
.thank-you-actions {
    margin-top:40px;
    display:flex; gap:16px;
    justify-content:center; flex-wrap:wrap;
}
</style>

<!-- NAV -->


<!-- Thank You -->
<section class="thank-you-section">
    <div class="container">
        <div class="thank-you-card">
            <div class="thank-you-icon">
                <svg viewBox="0 0 24 24">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <h1>Thank you for reaching out</h1>
            <p>Your message has been received. Our team typically responds within <span class="highlight">one business day</span>.</p>
            <p>While you wait, feel free to explore our CGM solutions and manufacturing capabilities.</p>
            <div class="thank-you-actions">
                <a href="/" class="btn btn-primary">Back to Home</a>
                <a href="/continuous-glucose-monitor" class="btn btn-outline">Explore CGM</a>
            </div>
        </div>
    </div>
</section>

<!-- FOOTER -->

</Base>
