---
import Base from '../layouts/Base.astro';

---
<Base
  title="Contact Us &mdash;EverCheck"
  description="Get in touch with EverCheck"
>
<style>
html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
            color: var(--brand-black);
            font-size: 16px;
            line-height: 1.75;
            -webkit-font-smoothing: antialiased;
        }

        /* ========== Typography ========== */
        h1 {
            font-size: 52px;
            font-weight: 700;
            letter-spacing: -1.5px;
            line-height: 1.15;
            color: var(--brand-black);
        }

        h2 {
            font-size: 36px;
            font-weight: 700;
            letter-spacing: -0.5px;
            line-height: 1.2;
            color: var(--brand-black);
        }

        h3 {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.6px;
            line-height: 1.3;
            color: var(--brand-black);
        }

        h4 {
            font-size: 17px;
            font-weight: 600;
            line-height: 1.4;
            color: var(--brand-black);
        }

        p {
            font-size: 16px;
            line-height: 1.75;
            color: var(--brand-gray);
        }

        /* ========== Buttons ========== */

        

/* ===== NAV DROPDOWN ===== */
        .hero {
            padding: 180px 0 120px;
            position: relative;
            overflow: hidden;
            text-align: center;
        }

        .hero-bg-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0.50);
            z-index: 1;
        }

        .hero .container {
            position: relative;
            z-index: 2;
        }

        .hero-content h1 {
            margin-bottom: 20px;
            font-size: 46px;
            line-height: 1.15;
        }

        .hero-content p {
            font-size: 17px;
            line-height: 1.7;
            max-width: 560px;
            margin: 0 auto 32px;
            color: var(--brand-gray);
        }

        /* ========== Contact Form Section ========== */
        .contact-section {
            padding: 80px 0;
            background: var(--white);
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1.3fr 1fr;
            gap: 64px;
            align-items: flex-start;
        }

        /* Form Styles */
        .contact-form-wrapper h2 {
            margin-bottom: 8px;
        }

        .contact-form-wrapper .section-desc {
            margin-bottom: 40px;
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 14px;
            font-weight: 500;
            color: var(--brand-black);
        }

        .form-group input,
        .form-group textarea {
            padding: 14px 18px;
            border: 1.5px solid var(--brand-border);
            border-radius: 12px;
            font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
            font-size: 16px;
            color: var(--brand-black);
            background: var(--white);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            outline: none;
            width: 100%;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 3px rgba(128,188,226,0.15);
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder {
            color: #b0b8c1;
        }

        .form-group textarea {
            min-height: 140px;
            resize: vertical;
        }

        .form-submit-row {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .form-submit-row .btn-primary {
            flex-shrink: 0;
        }

        .form-note {
            font-size: 13px;
            color: var(--brand-gray);
            line-height: 1.5;
        }

        /* Contact Info Sidebar */
        .contact-info {
            background: var(--brand-light-gray);
            border-radius: 16px;
            padding: 40px 32px;
        }

        .contact-info h3 {
            font-size: 20px;
            margin-bottom: 24px;
        }

        .contact-info-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .contact-info-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
        }

        .contact-info-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(128,188,226,0.10);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .contact-info-icon svg {
            width: 22px;
            height: 22px;
            stroke: var(--brand-blue);
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .contact-info-text h4 {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--brand-black);
        }

        .contact-info-text p,
        .contact-info-text a {
            font-size: 15px;
            color: var(--brand-gray);
            line-height: 1.55;
            text-decoration: none;
        }

        .contact-info-text a:hover {
            color: var(--brand-blue);
        }

        .contact-response-note {
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid var(--brand-border);
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .contact-response-note svg {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            margin-top: 1px;
            stroke: var(--brand-blue);
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .contact-response-note span {
            font-size: 14px;
            color: var(--brand-gray);
            line-height: 1.55;
        }

        /* ========== Footer ========== */

        /* ========== Responsive ========== */

    /* ===== FOOTER CTA ===== */
</style>

<!-- ==================== NAVIGATION ==================== -->


<!-- ==================== HERO SECTION ==================== -->
<section class="hero">
    <img class="hero-bg-img" src="/contact-hero-factory.jpg" alt="EverCheck factory and manufacturing facility">
    <div class="container">
        <div class="hero-content">
            <h1>Let's talk about your CGM project</h1>
            <p>Interested in our CGM solutions? Get in touch with our team to explore how we can support your business. Whether you are building a CGM brand, expanding into new healthcare markets, or integrating CGM into your system, we are ready to support your next stage of growth.</p>
            <a href="/contact" class="btn btn-primary">Contact us</a>
        </div>
    </div>
</section>

<!-- ==================== CONTACT FORM + INFO ==================== -->
<section class="contact-section">
    <div class="container">
        <div class="contact-grid">
            <!-- Left: Contact Form -->
            <div class="contact-form-wrapper">
                <h2>Send us a message</h2>
                <p class="section-desc">Fill out the form below and our team will get back to you within one business day.</p>

                <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
                    <input type="hidden" name="access_key" value="efeceb0a-a931-4c23-a3c6-e92b4bac78c5">
                    <input type="hidden" name="subject" value="New inquiry from EverCheck website">
                    <input type="hidden" name="from_name" value="EverCheck Website">
                    <input type="hidden" name="redirect" value="https://evercheck.pages.dev/thank-you.html">
                    <!-- Honeypot anti-spam -->
                    <input type="checkbox" name="botcheck" class="hidden" style="display:none;" tabindex="-1" autocomplete="off">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="Your full name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="you@company.com" required>
                    </div>
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" placeholder="Tell us about your project, requirements, or questions..." required></textarea>
                    </div>
                    <div class="form-submit-row">
                        <button type="submit" class="btn btn-primary">Send</button>
                        <span class="form-note">We respect your privacy and will never share your information.</span>
                    </div>
                </form>
            </div>

            <!-- Right: Contact Info -->
            <div class="contact-info">
                <h3>Contact Information</h3>
                <ul class="contact-info-list">
                    <li class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </div>
                        <div class="contact-info-text">
                            <h4>Email</h4>
                            <a href="mailto:contact@evercheck.bio">contact@evercheck.bio</a>
                        </div>
                    </li>
                    <li class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <div class="contact-info-text">
                            <h4>WhatsApp</h4>
                            <p>+86 191 6859 8056</p>
                        </div>
                    </li>
                    <li class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                        </div>
                        <div class="contact-info-text">
                            <h4>Location</h4>
                            <p>Room 902, Building 1, Hengtaiyu Building, Tangwei Community, Fenghuang Street, Guangming District, Shenzhen</p>
                        </div>
                    </li>
                </ul>

                <div class="contact-response-note">
                    <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span>You can expect a thoughtful reply within 24 hours. We treat every inquiry as the start of a partnership.</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==================== FOOTER ==================== -->

<!-- FOOTER CTA -->
<section class="section" id="contact">
  <div class="container">
    <div class="footer-cta">
      <h2>Your long-term B2B CGM manufacturing partner</h2>
      <p>We combine self-developed CGM technologies with scalable manufacturing infrastructure to support healthcare brands worldwide.</p>
      <a href="mailto:contact@evercheck.bio" class="btn btn-primary">Contact us now</a>
    </div>
  </div>
</section>

</Base>
