---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base
  title="Blog — EverCheck"
  description="Latest insights on CGM technology, manufacturing models, regulatory compliance, and healthcare business strategy from EverCheck."
>

<style is:global>
.breadcrumb{padding:96px 0 0;font-size:13px;color:var(--brand-gray);}
.breadcrumb a{color:var(--brand-gray);transition:color .2s;}
.breadcrumb a:hover{color:var(--brand-blue);}
.breadcrumb .sep{margin:0 6px;}
.page-hero{background:linear-gradient(135deg,var(--brand-black) 0%,#1a1a2e 100%);padding:60px 0 80px;color:var(--white);}
.page-hero-inner{max-width:700px;margin:0 auto;text-align:center;padding:0 24px;}
.page-hero h1{font-size:42px;font-weight:700;letter-spacing:-.8px;margin-bottom:16px;}
.page-hero p{font-size:18px;color:rgba(255,255,255,.75);line-height:1.7;}
.blog-grid-section{padding:80px 0;}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
.blog-card{display:flex;flex-direction:column;background:var(--white);border-radius:var(--radius-md);border:1px solid var(--brand-border);overflow:hidden;transition:box-shadow .2s,transform .2s;text-decoration:none;color:inherit;}
.blog-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px);}
.blog-card-img{aspect-ratio:16/9;background:var(--brand-light-gray);overflow:hidden;position:relative;}
.blog-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
.blog-card:hover .blog-card-img img{transform:scale(1.04);}
.blog-card-cat{position:absolute;top:12px;left:12px;background:var(--brand-blue);color:var(--white);font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px;}
.blog-card-body{padding:24px;flex:1;}
.blog-card-body h3{font-size:17px;font-weight:600;line-height:1.45;margin-bottom:12px;color:var(--brand-black);}
.blog-card-meta{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--brand-gray);}
.dot{width:3px;height:3px;border-radius:50%;background:var(--brand-gray);}
@media(max-width:900px){.blog-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:600px){.blog-grid{grid-template-columns:1fr;}.page-hero h1{font-size:28px;}}
</style>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <div class="container">
    <a href="/">Home</a>
    <span class="sep">&rsaquo;</span>
    <span>Blog</span>
  </div>
</div>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <h1>Blog</h1>
      <p>Insights on CGM technology, manufacturing models, regulatory compliance, and healthcare business strategy.</p>
    </div>
  </div>
</section>

<!-- BLOG GRID — auto-populated from src/content/blog/ -->
<section class="blog-grid-section">
  <div class="container">
    {posts.length === 0 ? (
      <p style="text-align:center;color:var(--brand-gray);padding:60px 0;">No posts yet. Add Markdown files to <code>src/content/blog/</code>.</p>
    ) : (
      <div class="blog-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="blog-card">
            <div class="blog-card-img">
              <span class="blog-card-cat">{post.data.category}</span>
              {post.data.coverImage && (
                <img src={post.data.coverImage} alt={post.data.coverAlt ?? post.data.title} loading="lazy">
              )}
            </div>
            <div class="blog-card-body">
              <h3>{post.data.title}</h3>
              <div class="blog-card-meta">
                <span>{post.data.author}</span>
                <span class="dot"></span>
                <span>{formatDate(post.data.pubDate)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

</Base>
